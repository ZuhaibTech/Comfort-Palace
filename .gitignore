# =============================================================================
# NEXT.JS / NODE.JS - .gitignore
# =============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Outputs ─────────────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ── Environment Variables (NEVER commit secrets) ──────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ── Next.js Cache ─────────────────────────────────────────────────────────────
.next/cache/

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Package Manager Locks (keep only one) ─────────────────────────────────────
# Uncomment the ones you DON'T use:
# yarn.lock
# pnpm-lock.yaml

# ── OS Artifacts ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pem
.cache/
